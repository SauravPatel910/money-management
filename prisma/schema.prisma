generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  moneyAccounts MoneyAccount[]
  transactions  Transaction[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model MoneyAccount {
  dbId      String   @id @default(cuid()) @map("db_id")
  id        String
  name      String
  owner     String?
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  icon      String   @default("bank")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, id])
  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id              String   @id @default(cuid())
  type            String
  amount          Decimal  @db.Decimal(14, 2)
  account         String?
  from            String?  @map("from_account")
  to              String?  @map("to_account")
  direction       String?
  person          String?
  note            String?
  transactionDate DateTime @map("transaction_date")
  entryDate       DateTime @map("entry_date")
  accountBalances Json?    @map("account_balances")
  totalBalance    Decimal  @default(0) @map("total_balance") @db.Decimal(14, 2)
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  editHistory     TransactionEditHistory[]

  @@index([userId])
  @@index([account])
  @@index([from])
  @@index([to])
  @@index([transactionDate])
  @@map("transactions")
}

model TransactionEditHistory {
  id             String      @id @default(cuid())
  transactionId  String      @map("transaction_id")
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  editedAt       DateTime    @default(now()) @map("edited_at")
  beforeSnapshot Json        @map("before_snapshot")
  afterSnapshot  Json        @map("after_snapshot")
  changedFields  Json        @map("changed_fields")

  @@index([transactionId])
  @@index([editedAt])
  @@map("transaction_edit_history")
}
